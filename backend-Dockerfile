FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code + config
COPY *.py .
COPY config.yaml .

# Copy vector store (baked into the image)
COPY vdb/ ./vdb/

EXPOSE 8000

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]

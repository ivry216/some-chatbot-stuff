# ── Build stage ──
FROM node:18-alpine AS build
WORKDIR /app

COPY package.json ./
RUN npm install

# In Docker, frontend talks to backend via nginx proxy at /api
ENV REACT_APP_API_URL=/api

COPY public/ public/
COPY src/ src/
RUN npm run build

# ── Production stage ──
FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
